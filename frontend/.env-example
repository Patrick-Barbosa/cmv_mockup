# Copie este arquivo para .env e preencha com seus valores

# URL base do backend (sem barra no final)
# Desenvolvimento local:
VITE_BACKEND_URL=http://127.0.0.1:8000

# Produção (exemplo Render/Railway):
# VITE_BACKEND_URL=https://meu-backend.onrender.com

# ── Running the Application ───────────────────────────────────────────────────
# Frontend (Vite + React):
#   cd frontend
#   npm install
#   npm run dev