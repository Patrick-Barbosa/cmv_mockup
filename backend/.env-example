# ── Environment ──────────────────────────────────────────────────────────────
# Controls app behaviour: "development" or "production"
# - development: tables are dropped + recreated on startup, seed data is inserted
# - production:  tables are created only if they don't exist, no data wipe
APP_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase asyncpg URL.  Replace [YOUR-PASSWORD] with your actual password.
#
# For local dev with a local PostgreSQL instance:
#   DATABASE_URL=postgresql+asyncpg://postgres:123@localhost/cmv_00
#
# For Docker Compose:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cmv_00
#
# For Supabase (production — public schema):
#   DATABASE_URL=postgresql+asyncpg://postgres.ulhsxdzxolqljrsgjury:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
#
# For Supabase (development — development schema):
#   DATABASE_URL=postgresql+asyncpg://postgres.ulhsxdzxolqljrsgjury:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
#
# The active schema (public vs development) is chosen automatically from APP_ENV,
# so the same base URL can be used for both environments on Supabase.
DATABASE_URL=postgresql+asyncpg://postgres:123@localhost/cmv_00

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In development with APP_ENV=development this defaults to "*" if left empty.
# In production you MUST set this to your Vercel URL.
# Example: ALLOWED_ORIGINS=https://prato.vercel.app,https://www.prato.app
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:5500

# ── Running the Application ───────────────────────────────────────────────────
# Backend (FastAPI):
#   cd backend
#   uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
